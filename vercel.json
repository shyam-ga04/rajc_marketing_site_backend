{
  "version": 2,
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/main.ts"
    },
    {
      "src": "/swagger-ui(.css|.js)(.*)",
      "dest": "src/main.ts"
    },
    {
      "src": "/swagger-ui-bundle(.js)(.*)",
      "dest": "src/main.ts"
    },
    {
      "src": "/swagger-ui-standalone-preset(.js)(.*)",
      "dest": "src/main.ts"
    },
    {
      "src": "/swagger-initializer(.js)(.*)",
      "dest": "src/main.ts"
    },
    {
      "src": "/favicon.ico",
      "dest": "src/main.ts"
    },
    {
      "src": "/swagger-json",
      "dest": "src/main.ts"
    },
    {
      "src": "/(.*)",
      "dest": "src/main.ts"
    }
  ]
}
